# Database init environment (used by database/init_tables.py)

# Target database for project storage schema
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=z_graph
POSTGRES_USER=z_graph
POSTGRES_PASSWORD=zep_graph_password

# Optional overrides for target connection
PROJECT_STORAGE_CONNECTION_STRING=

# Host port mapping for Docker postgres service (docker compose)
POSTGRES_HOST_PORT=

# Auto-provision target role/database on an existing admin-accessible Postgres
DB_INIT_AUTO_PROVISION=true
POSTGRES_BOOTSTRAP_URL=
POSTGRES_BOOTSTRAP_HOST=localhost
POSTGRES_BOOTSTRAP_PORT=5432
POSTGRES_BOOTSTRAP_USER=postgres
POSTGRES_BOOTSTRAP_PASSWORD=postgres
POSTGRES_BOOTSTRAP_DB=postgres

# Init retry settings
DB_INIT_MAX_ATTEMPTS=20
DB_INIT_RETRY_DELAY_SECONDS=1.5
