APP_NAME=zep_graph_backend
APP_ENV=development
API_PREFIX=/api
HOST=0.0.0.0
PORT=8000
STORAGE=postgres
PROJECT_STORAGE_CONNECTION_STRING=postgresql://z_graph:zep_graph_password@localhost:5432/z_graph
POSTGRES_HOST=postgresql://postgres:postgres@localhost:5432/postgres
POSTGRES_PORT=5434
POSTGRES_DB=z_graph
POSTGRES_USER=z_graph
POSTGRES_PASSWORD=zep_graph_password
UPLOAD_FOLDER=uploads
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-5.2
MAX_TEXT_LENGTH_FOR_LLM=150000
LLM_MAX_RETRIES=3
LLM_INITIAL_DELAY_SECONDS=1.0
LLM_MAX_DELAY_SECONDS=30.0
LLM_BACKOFF_FACTOR=2.0
# Frontend polling interval for /api/task/{task_id}, surfaced by /api/health.
TASK_POLL_INTERVAL_MS=2000
# Frontend interval for /api/data/{graph_id} while graph build is running (heavier than task poll).
GRAPH_DATA_POLL_INTERVAL_MS=10000
# Episodes per batch for Step B graph build (POST /api/build may send batch_size to override).
GRAPH_BUILD_BATCH_SIZE=5
# Timeout per graph for background cache warm-up in GET /api/project/{project_id}.
PROJECT_GET_WARMUP_TIMEOUT_SECONDS=3
# Dedupe window for repeated warm-up of same project+ontology+graph.
PROJECT_GET_WARMUP_DEDUPE_TTL_SECONDS=30
LANGFUSE_SECRET_KEY="sk-lf-8350831e-1b71-4f9f-88db-e4f2026393ca"
LANGFUSE_PUBLIC_KEY="pk-lf-c198c93d-aff8-413d-902f-5193b11b0eec"
LANGFUSE_BASE_URL="http://localhost:3000"
# Prompt source backend:
# - file: use local files under app/core/langfuse_versioning (default)
# - langfuse: fetch from Langfuse first, fallback to local files
PROMPT_BACKEND=file
# Default prompt label when request does not provide one.
PROMPT_LABEL=production
# Langfuse prompt cache TTL in seconds (only used when PROMPT_BACKEND=langfuse).
PROMPT_CACHE_TTL_SECONDS=300
# Enable dedicated Graphiti -> Langfuse OTel tracing.
APPLY_LANGFUSE_TO_GRAPHITI_TRACE=true
# Optional override; default is {LANGFUSE_BASE_URL}/api/public/otel.
LANGFUSE_OTEL_ENDPOINT=""
# Optional override. Leave empty to auto-generate:
# "Basic base64(LANGFUSE_PUBLIC_KEY:LANGFUSE_SECRET_KEY)".
LANGFUSE_OTEL_AUTH=""
ZEP_API_KEY=
ZEP_BACKEND=graphiti
# Graphiti graph database driver mode: neo4j | oracle
GRAPHITI_DB=neo4j
GRAPHITI_LLM_MODEL=gpt-5.2
GRAPHITI_LLM_SMALL_MODEL=gpt-4o-mini
GRAPHDB_URI=bolt://localhost:7687
GRAPHDB_USER=neo4j
GRAPHDB_PASSWORD=password
# Optional Oracle DSN mode for Graphiti driver:
# GRAPHDB_DSN=localhost:1521/FREEPDB1
# Graphiti Oracle RDF network settings (used when GRAPHDB_DSN is set).
# Set ORACLE_USE_RDF=true to auto-create/read RDF network + graph tables.
ORACLE_USE_RDF=false
# Enable Oracle SQL query logging inside graphiti-core (if supported by installed version).
ORACLE_LOG_QUERIES=false
# graphiti_core uses stdlib logging; uvicorn hides third-party INFO by default. Set to INFO or DEBUG to print it.
# GRAPHITI_LOG_LEVEL=INFO
# Neo4j driver in current graphiti-core does not expose a query-log env toggle.
# Defaults to ORACLE_USER / GRAPHDB_USER when empty.
ORACLE_RDF_NETWORK_OWNER=
# Defaults to NET1 when empty.
ORACLE_RDF_NETWORK_NAME=
# Defaults to GRAPHITI when empty.
ORACLE_RDF_GRAPH_NAME=
# Defaults to DATA when empty.
ORACLE_RDF_TABLESPACE=
# Oracle async pool defaults for python-oracledb async pool.
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=8
ORACLE_POOL_INCREMENT=1
# Limits concurrent coroutines inside OraclePGDriver.
ORACLE_MAX_COROUTINES=

# Comma-separated list for UI options; first item is default.
GRAPHITI_EMBEDDING_MODEL=text-embedding-3-large
GRAPHITI_EMBEDDING_API_KEY=
GRAPHITI_EMBEDDING_BASE_URL=https://api.openai.com/v1

OPENAI_API_KEY=
OPENAI_BASE_URL=